# Database (Docker uses these defaults, local dev may differ)
DATABASE_URL=postgresql+asyncpg://warren:warren@db:5432/warren
POSTGRES_DB=warren
POSTGRES_USER=warren
POSTGRES_PASSWORD=warren

# Redis
REDIS_URL=redis://redis:6379/0

# API Keys — get your own at the URLs below
FRED_API_KEY=              # https://fred.stlouisfed.org/docs/api/api_key.html
ALPHA_VANTAGE_API_KEY=     # https://www.alphavantage.co/support/#api-key
FINNHUB_API_KEY=           # https://finnhub.io/register

# Application
LOG_LEVEL=INFO
TZ=Europe/Helsinki

# Frontend URL — used for CORS. Change to your domain when behind a reverse proxy.
# Examples: http://localhost:3000, http://bloomvalley.example.com
FRONTEND_URL=http://localhost:3000

# Custom data storage (optional — defaults to ./data/postgres and ./data/redis)
# POSTGRES_DATA_DIR=/mnt/storage/bloomvalley/postgres
# REDIS_DATA_DIR=/mnt/storage/bloomvalley/redis
